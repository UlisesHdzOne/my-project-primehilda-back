generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CONSUMER
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  password  String
  phone     String   @unique
  role      Role     @default(CONSUMER)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
