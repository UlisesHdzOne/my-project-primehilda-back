generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role     Role   @default(CONSUMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Address {
  id        Int     @id @default(autoincrement())
  name      String
  street    String
  colony    String
  reference String
  zipCode   String?
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  CONSUMER
  ADMIN
  MODERATOR
}
