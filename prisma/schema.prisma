generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  lastName  String   @default("modificar apellido")
  email     String?  
  password  String
  phone     String   @unique
  role      String   @default("CONSUMER")

  document  String?  @unique
  notes     String?
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
  addresses Address[]
  carts     Cart[]
}

model Address {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String   // "Casa", "Trabajo", "Oficina", etc.
  address     String   // Dirección completa
  city        String
  state       String
  zipCode     String
  country     String   @default("México")
  notes       String?  // "Casa blanca portón negro"
  isDefault   Boolean  @default(false)
  latitude    Float?   // Para geolocalización
  longitude   Float?   // Para geolocalización
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("addresses")
  @@index([userId])
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  description String?
  price     Float
  imageUrl  String?
  category  String
  isActive  Boolean @default(true)
  hasGifts   Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

 // Relación inversa con GiftRule
  giftRule    GiftRule? @relation("ProductAsPrincipal")
  cartItems   CartItem[]
  
  @@map("products")
}

model GiftRule {
  id                  Int      @id @default(autoincrement())

  // Producto principal (el que otorga los obsequios)
  principalProductId  Int
  principalProduct    Product  @relation("ProductAsPrincipal", fields: [principalProductId], references: [id], onDelete: Cascade)

  // Configuración de obsequios
  allowedGiftIds      Int[]    // IDs de productos que pueden ser regalos
  maxFreeQuantity     Int
  isActive            Boolean  @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("gift_rules")
  @@unique([principalProductId])
  @@index([principalProductId])
  @@index([isActive])
}

model Cart {
  id        Int      @id @default(autoincrement())
  userId    Int
  sessionId String?  // Para usuarios no logueados
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@map("carts")
  @@index([userId])
  @@index([sessionId])
}

model CartItem {
  id        Int     @id @default(autoincrement())
  cartId    Int
  productId Int
  quantity  Int     @default(1)
  
  // Para obsequios
  isGift    Boolean @default(false)
  giftFromProductId Int?  // Producto principal que dio este obsequio
  createdAt DateTime @default(now())

  // Relations
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("cart_items")
  @@unique([cartId, productId, isGift, giftFromProductId])
  @@index([cartId])
  @@index([productId])
}