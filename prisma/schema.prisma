// prisma/schema.prisma - BUSINESS ENGLISH
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== BUSINESS-ORIENTED ENUMS ====================
enum WashStatus {
  WAITING        // Vehicle arrived, waiting turn
  WASHING        // Currently being washed
  COMPLETED      // Wash finished
  READY          // Ready for customer pickup
  DELIVERED      // Customer picked up the vehicle
  CANCELLED      // Wash cancelled
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

// ==================== BUSINESS MODELS ====================

// A VEHICLE that comes for washing
model Vehicle {
  id          Int         @id @default(autoincrement())
  plateNumber String      @unique @db.VarChar(15)  // ABC-123
  brand       String      @db.VarChar(50)          // Toyota, Honda
  model       String      @db.VarChar(50)          // Corolla, Civic
  color       String      @db.VarChar(30)
  isActive    Boolean     @default(true)           // Soft delete
  notes       String?     @db.Text                 // "Scratch on door"
  registeredAt DateTime   @default(now())
  updatedAt   DateTime    @updatedAt
  
  // Relations
  washes      Wash[]      // A vehicle can have many washes
  
  @@map("vehicles")
  @@index([plateNumber])
  @@index([isActive])
  @@index([registeredAt])
}

// SERVICES we offer (catalog)
model WashService {
  id          Int         @id @default(autoincrement())
  name        String      @db.VarChar(100)         // "Premium Exterior Wash"
  description String?     @db.Text
  price       Decimal     @db.Decimal(10, 2)       // Monetary precision
  duration    Int                                  // Minutes to complete
  category    String      @db.VarChar(30)          // "exterior", "interior", "complete"
  isActive    Boolean     @default(true)           // To deactivate services
  createdAt   DateTime    @default(now())
  
  // Relations
  washItems   WashItem[]  // A service can be in many washes
  
  @@map("wash_services")
  @@index([category])
  @@index([isActive])
  @@index([price])
}

// A WASH ORDER (core business model)
model Wash {
  id          Int           @id @default(autoincrement())
  washNumber  String        @unique @db.VarChar(20)  // WASH-2024-001
  vehicleId   Int
  status      WashStatus    @default(WAITING)
  
  // Timeline
  arrivedAt   DateTime      @default(now())     // When vehicle arrived
  startedAt   DateTime?                         // When wash started
  completedAt DateTime?                         // When wash finished
  readyAt     DateTime?                         // When ready for pickup
  deliveredAt DateTime?                         // When customer picked up
  cancelledAt DateTime?                         // If cancelled
  
  // Financial info
  subtotal    Decimal       @db.Decimal(10, 2)
  discount    Decimal?      @db.Decimal(10, 2) @default(0)
  total       Decimal       @db.Decimal(10, 2)
  
  // Notes for THIS specific wash
  washNotes   String?       @db.Text           // "Don't wash engine", "Customer prefers wax X"
  
  // Relations
  vehicle     Vehicle       @relation(fields: [vehicleId], references: [id])
  items       WashItem[]
  payments    Payment[]
  
  @@map("washes")
  @@index([vehicleId])
  @@index([status])
  @@index([arrivedAt])
  @@index([washNumber])
}

// ITEMS (services) in each wash
model WashItem {
  id          Int     @id @default(autoincrement())
  washId      Int
  serviceId   Int
  quantity    Int     @default(1)
  price       Decimal @db.Decimal(10, 2)  // Price at time of wash
  
  // Relations
  wash        Wash        @relation(fields: [washId], references: [id])
  service     WashService @relation(fields: [serviceId], references: [id])
  
  @@map("wash_items")
  @@unique([washId, serviceId])  // Don't duplicate services in a wash
  @@index([washId])
  @@index([serviceId])
}

// PAYMENTS for a wash
model Payment {
  id          Int           @id @default(autoincrement())
  washId      Int
  amount      Decimal       @db.Decimal(10, 2)
  method      PaymentMethod
  reference   String?       @db.VarChar(50)    // "REC-001", "TRF-123"
  notes       String?       @db.Text          // "Payment with card ending 1234"
  paidAt      DateTime      @default(now())
  
  // Relation
  wash        Wash          @relation(fields: [washId], references: [id])
  
  @@map("payments")
  @@index([washId])
  @@index([paidAt])
  @@index([method])
}