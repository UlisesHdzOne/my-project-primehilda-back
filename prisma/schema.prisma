generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relación: 1 Usuario → N Reservas
  reservas Reserva[]
}

model Sala{
  id        Int      @id @default(autoincrement())
  name      String
  capacity Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

   // Relación: 1 Sala → N Reservas
  reservas  Reserva[]
}

model Reserva{
  id        Int      @id @default(autoincrement())
  fecha     DateTime
  horaInicio String
  horaFin   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

   // FK hacia User
  userId     Int
  user       User      @relation(fields: [userId], references: [id])

  // FK hacia Sala
  salaId     Int
  sala       Sala      @relation(fields: [salaId], references: [id])
}