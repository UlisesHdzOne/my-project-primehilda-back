generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUMS para estados (en español para la app)
enum OrderStatus {
  PENDIENTE      @map("pending")
  EN_PROCESO     @map("in_progress") 
  TERMINADO      @map("done")
  LISTO_ENTREGA  @map("ready_for_delivery")
  ENTREGADO      @map("delivered")
  CANCELADO      @map("cancelled")
}

enum PaymentMethod {
  EFECTIVO  @map("cash")
  TARJETA   @map("card")
  TRANSFERENCIA @map("transfer")
}

// MODELOS PRINCIPALES
model Car {
  id          Int      @id @default(autoincrement())
  plate       String   @unique  // Placa única
  brand       String
  model       String
  color       String
  isActive    Boolean  @default(true)  // Para "archivar"
  notes       String?  // Notas del auto (rayones, etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      Order[]  // Relación 1:N

  @@map("cars")
}

model Service {
  id          Int      @id @default(autoincrement())
  name        String   // "Lavado exterior básico"
  description String?  // "Incluye lavado de carrocería y llantas"
  price       Float
  duration    Int      // Duración en minutos
  category    String   // "exterior", "interior", "premium"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  orderItems  OrderItem[]  // Relación N:M a través de OrderItem

  @@map("services")
  @@index([category])
  @@index([isActive])
}

model Order {
  id           Int       @id @default(autoincrement())
  orderNumber  String    @unique  // "ORD-2025-001"
  carId        Int
  status       OrderStatus @default(PENDIENTE)
  
  // Timestamps del flujo
  createdAt    DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  readyAt      DateTime?  // Cuando está listo para entrega
  deliveredAt  DateTime?
  cancelledAt  DateTime?
  
  // Precios
  subtotal     Float
  discount     Float? @default(0)
  total        Float
  
  // Notas
  notes        String?   // "Cliente pidió no lavar motor"
  
  // Relaciones
  car          Car       @relation(fields: [carId], references: [id])
  items        OrderItem[]
  payments     Payment[]
  
  @@map("orders")
  @@index([carId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id         Int     @id @default(autoincrement())
  orderId    Int
  serviceId  Int
  quantity   Int     @default(1)
  price      Float   // Precio al momento de la orden
  
  order      Order   @relation(fields: [orderId], references: [id])
  service    Service @relation(fields: [serviceId], references: [id])
  
  @@map("order_items")
  @@unique([orderId, serviceId])
}

model Payment {
  id        Int           @id @default(autoincrement())
  orderId   Int
  amount    Float
  method    PaymentMethod
  reference String?       // Referencia de pago
  notes     String?       // "Pago con tarjeta terminación 1234"
  createdAt DateTime      @default(now())
  
  order     Order         @relation(fields: [orderId], references: [id])
  
  @@map("payments")
  @@index([orderId])
}