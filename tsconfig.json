{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node16", // ← CAMBIADO: Mejor compatibilidad
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,

    // 🔒 ESTAS SON BUENAS - MANTENER
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,

    // 🚫 DETECTAR BASURA - MANTENER
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    // 🔄 OPCIONES FLEXIBLES - MANTENER
    "useDefineForClassFields": false,
    "exactOptionalPropertyTypes": false,

    "paths": {
      "@/*": ["src/*"],
      "@common/*": ["src/common/*"],
      "@shared/*": ["src/shared/*"],
      "@modules/*": ["src/modules/*"],
      "@config/*": ["src/config/*"],
      "@database/*": ["src/database/*"]
    }
  },

  "ts-node": {
    "require": ["tsconfig-paths/register"],
    "transpileOnly": true, // ← AGREGADO: Más rápido
    "files": true // ← AGREGADO: Mejor compatibilidad
  }
}
