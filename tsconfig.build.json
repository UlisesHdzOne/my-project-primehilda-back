{
  "extends": "./tsconfig.json",

  "compilerOptions": {
    // Optimizaciones para producción
    "sourceMap": false,
    "declarationMap": false,
    "removeComments": true,
    "importHelpers": true
  },

  // Solo incluir código fuente (no tests)
  "include": ["src/**/*"],

  // Excluir explícitamente tests y archivos no necesarios
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*.spec.ts",
    "**/*.e2e-spec.ts",
    "**/*.test.ts",
    "prisma/seed.ts",
    "scripts"
  ]
}
