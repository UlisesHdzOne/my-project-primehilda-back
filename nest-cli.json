{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",

  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "tsconfig.build.json",
    "webpack": false,
    "assets": [
      {
        "include": "**/*.prisma",
        "outDir": "./dist",
        "watchAssets": false
      }
    ],
    "watchAssets": false
  },

  "generateOptions": {
    "spec": true,
    "flat": false
  },

  "monorepo": false,
  "root": "."
}
